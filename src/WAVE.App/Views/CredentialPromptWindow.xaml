<Window x:Class="WAVE.App.Views.CredentialPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WAVE — Credencial de rede" Height="400" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}" Foreground="{StaticResource BrushText}"
        FontFamily="Segoe UI">
    <Border Padding="26">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,4" TextWrapping="Wrap" />
            <TextBlock Text="Rede protegida. Informe a credencial para conectar." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16" />

            <Label Content="Sen_ha / Passphrase" Target="{Binding ElementName=PassphraseInput}" Style="{StaticResource FieldLabel}" />
            <PasswordBox x:Name="PassphraseInput" Height="30" Margin="0,2,0,10" ToolTip="Senha da rede protegida" />

            <StackPanel x:Name="EnterprisePanel">
                <Label Content="_Usuário" Target="{Binding ElementName=UsernameInput}" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="UsernameInput" Height="30" Margin="0,2,0,10" ToolTip="Usuário de autenticação (rede Enterprise)" />

                <Label Content="_Domínio" Target="{Binding ElementName=DomainInput}" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="DomainInput" Height="30" Margin="0,2,0,10" ToolTip="Domínio de autenticação (rede Enterprise)" />
            </StackPanel>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource BrushFailed}" TextWrapping="Wrap"
                       Margin="0,2,0,10" Visibility="Collapsed" />

            <Button Content="Conectar" Click="OnSubmit" IsDefault="True"
                    Style="{StaticResource ActionButtonStyle}" Height="42" Margin="0,6,0,0" />
        </StackPanel>
    </Border>
</Window>
