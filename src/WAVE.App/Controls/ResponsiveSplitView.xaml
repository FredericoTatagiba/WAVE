<UserControl x:Class="WAVE.App.Controls.ResponsiveSplitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid">
        <ContentPresenter x:Name="PrimaryHost"
                          Content="{Binding PrimaryContent, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        <ContentPresenter x:Name="SecondaryHost"
                          Content="{Binding SecondaryContent, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
    </Grid>
</UserControl>
