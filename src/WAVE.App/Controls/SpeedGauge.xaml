<UserControl x:Class="WAVE.App.Controls.SpeedGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="#FF0E1621" CornerRadius="8" Padding="12">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Current phase (only visible while measuring) -->
            <TextBlock Grid.Row="0"
                       Text="{Binding PhaseText, ElementName=Root}"
                       Visibility="{Binding PhaseText, ElementName=Root, Converter={StaticResource NonEmptyToVis}}"
                       Foreground="{StaticResource BrushAccent}"
                       FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />

            <!-- Hero number: live download speed -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DownloadMbps, ElementName=Root, StringFormat={}{0:0.#}}"
                       Foreground="{StaticResource BrushText}"
                       FontSize="52" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <TextBlock Grid.Row="2" Text="Mbps"
                       Foreground="{StaticResource BrushMuted}"
                       FontSize="14" HorizontalAlignment="Center" Margin="0,-6,0,0" />

            <TextBlock Grid.Row="3" Text="↓ Download"
                       Foreground="{StaticResource BrushMuted}"
                       FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" />

            <!-- Secondary: upload -->
            <TextBlock Grid.Row="4" HorizontalAlignment="Center" Margin="0,10,0,0"
                       Foreground="{StaticResource BrushMuted}" FontSize="14">
                <Run Text="↑" />
                <Run Text="{Binding UploadMbps, ElementName=Root, Mode=OneWay, StringFormat={}{0:0.#}}"
                     Foreground="{StaticResource BrushText}" FontWeight="SemiBold" />
                <Run Text="Mbps upload" />
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
