<UserControl x:Class="WAVE.App.Controls.NetworkButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button Command="{Binding RunCommand}"
            IsEnabled="{Binding IsEnabled}"
            Background="{Binding State, Converter={StaticResource StateToBrush}}"
            Style="{StaticResource TouchButtonStyle}"
            Margin="6">
        <StackPanel>
            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
            <TextBlock Text="{Binding Ssid}" FontSize="12" Opacity="0.85" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Info}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>
    </Button>
</UserControl>
