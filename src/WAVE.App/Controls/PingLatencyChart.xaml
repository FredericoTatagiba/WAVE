<UserControl x:Class="WAVE.App.Controls.PingLatencyChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FF0E1621" CornerRadius="8" Padding="8">
        <Grid>
            <Canvas x:Name="PlotCanvas" ClipToBounds="True" Background="Transparent" />
            <TextBlock x:Name="EmptyLabel"
                       Text="Sem dados de ping"
                       Foreground="#FF8899A6"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
